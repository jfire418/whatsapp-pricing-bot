# WhatsApp Cloud API (from Meta Developer Portal)
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Drive (Service Account JSON — paste the whole JSON as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Drive File IDs for each PDF (get from the share URL)
DRIVE_FILE_WEDDING=your_google_drive_file_id
DRIVE_FILE_EVENT=your_google_drive_file_id
DRIVE_FILE_PORTRAIT=your_google_drive_file_id
DRIVE_FILE_CORPORATE=your_google_drive_file_id
DRIVE_FILE_GENERAL=your_google_drive_file_id

# Logs endpoint protection — /logs requires ?token=<this value>.
# Leave unset to disable the /logs endpoint entirely.
LOGS_TOKEN=any_random_secret_you_choose

# Conversation persistence — JSON file path. On Railway, point this at a
# mounted volume (e.g. /data/conversations.json) so chats survive redeploys.
CONVERSATIONS_PATH=

# Server
PORT=3000
